MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 961235371}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: fce8b1ddf3655624590e578fb42cb521, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::CompanyInteraction
  questionMark: {fileID: 1183944740}
  companyPanel: {fileID: 2057730542}
  resultPanel: {fileID: 2057730542}
  companyTitleText: {fileID: 1603052537}
  companyBodyText: {fileID: 899156377}
  hintText: {fileID: 877619149}
  resultTitleText: {fileID: 1603052537}
  resultBodyText: {fileID: 899156377}
  resultButtonText: {fileID: 0}
  companyName: '<color=#6B4712><size=125%><b>Big Tech Company</b></size></color>

'
  requirementText: '<color=#6B4712><b>Job Description:</b></color>

    Work on products
    used by millions, attend meetings about meetings, and live with the constant
    fear of being replaced by automation, outsourcing, or the next restructuring
    email.


    <color=#6B4712><b>Qualification:</b></color>

    Resume score 85+.

    Work
    experience mini-game required.

    Networking mini-game required.

    Must
    convince everyone you are "high impact."


    <color=#6B4712><b>Offer:</b></color>

    High
    salary.

    Free snacks, big title, and permanent layoff anxiety.'
  companyTier: big_tech
  successResultBody: "<color=#2E7D32><b>APPLICATION RESULT: ACCEPTED</b></color>\nCongratulations.
    Welcome to Big Tier.\nAfter passing several filters, evaluations, and mysterious
    internal processes,\nyour application has finally been approved.\nYour daily
    activities may include:\n\u2022 Attending meetings about meetings  \n\u2022 Explaining
    simple ideas with very complicated slides  \n\u2022 Waiting for approvals from
    three different managers\nPerformance will be measured using carefully designed
    metrics that nobody fully understands but everyone pretends to.\n              
    <color=#6B4712><size=100%><b>Ready to be laid off </b></size></color>\n              
    <color=#6B4712><size=100%><b>in the coming days?   </b></size></color>"
  requirementBlockedResultBody: "Your application cannot proceed.\n\n<color=#6B4712><b>Minimum
    Requirements:</b></color>\n\n\u2022 Resume score: 85+  \n\u2022 Project mini-game
    completed  \n\u2022 Networking mini-game completed  \n\u2022 Work experience
    mini-game completed  \n\u2022 Certificate mini-game completed  \n\u2022 Must
    already succeed in both Startup and Mid-tier company tracks\n\nBig Tier companies
    only consider candidates who already appear successful everywhere else."
  declinedResultBody: "<color=#8B0000><b>APPLICATION RESULT: DECLINED</b></color>\nYour
    application entered the Big Tier hiring pipeline.\nUnfortunately the number of
    applicants was extremely large.\nOur hiring manager briefly looked at the resume
    pile, trashed half of them, and said:\n\u201CWe also don't want to work with
    unlucky people.\u201D\nYour resume may have been in that half.\nThank you for
    your interest in this company. Better luck with the next algorithm.\nAdditionally,
    we may include <linkunknown> to some of our products so you can rate them, review
    them, and help increase our sales."
