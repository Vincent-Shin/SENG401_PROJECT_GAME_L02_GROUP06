--- !u!114 &1790937643
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1790937638}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9aa38e470e8b67c4d87c6b7f99212d0c, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NetworkingMemoryMinigameInteraction
  questionMark: {fileID: 1930476661}
  entryPanel: {fileID: 164819758}
  entryTitleText: {fileID: 1924813065}
  entryDescriptionText: {fileID: 700491124}
  entryInstructionText: {fileID: 1174706831}
  entryHintText: {fileID: 702419857}
  entryTitle: Networking Memory Test
  entryDescription: "<size=125%>Description:</size>\nYou\u2019ve met many people
    while networking, but somehow forgot their names and where they work.\nLuckily,
    you still remember a few clues."
  requirementText: 'Each round shows one Name hint and one Company hint.

    Enter
    the correct Name and Company.

    Both must be correct to win.

    Points are
    awarded only the first time you play.'
  enterHint: Press ENTER to play.
  gameplayPanel: {fileID: 1287212334}
  gameplayTitleText: {fileID: 596806029}
  nameHintText: {fileID: 419965081}
  companyHintText: {fileID: 1954921453}
  nameInputField: {fileID: 724617146}
  companyInputField: {fileID: 204410432}
  gameplayHintText: {fileID: 1260325648}
  resultPanel: {fileID: 2128079652}
  resultTitleText: {fileID: 548975608}
  resultBodyText: {fileID: 1366246343}
  resultHintText: {fileID: 693409573}
  winTitle: Networking Success
  winBody: 'You somehow remembered both the name and the company correctly.

    The
    person nods approvingly, impressed that you remembered them.

    They say:

    "Nice
    to see someone with actual memory at these events."

    Your networking reputation
    increases.'
  winHint: Press ENTER to exit
  loseTitle: Networking Failure
  loseBody: 'You confidently guessed wrong and turned a normal conversation into
    a small social disaster.

    They stare at you for a second, politely, the way
    people look at corrupted spreadsheets.

    Your networking reputation survives,
    but only because nobody expects much from mixers anyway.'
  loseHint: Names and companies both matter. Social recovery is expensive.Press ENTER
    to exit.
  activityId: networking_game
  activityType: networking
  scoreReward: 5
  oneTimeOnly: 1
  nameCards:
  - answer: Ronnie
    hint: 'Starts with R

      6 letters

      Your favorite teacher in SENG401,
      but the difficulty of the tests changes depending on his mood.'
  - answer: Trump
    hint: 'Starts with T

      5 letters

      A politician who treats social media
      like a multiplayer game.

      Sometimes one post can move the price of Bitcoin.'
  - answer: Elon
    hint: 'Starts with E

      4 letters

      Extremely rich tech billionaire
      who launches rockets when he gets bored.'
  - answer: Gordon
    hint: 'Starts with G

      6 letters

      Famous chef known for cooking shows
      and extremely creative curse words.'
  - answer: Cristiano
    hint: 'Starts with C

      9 letters

      Football legend with the celebration
      "Siuuu".

      Some people call him GOAT.'
  - answer: Rahul
    hint: 'Starts with R

      5 letters

      A very common Indian name.

      You''ll
      probably see this name many times on the "Top Tech Employers" employee list.'
  - answer: Kevin
    hint: 'Starts with K

      5 letters

      Rhymes with "seven".

      A classic
      office name you''ll hear everywhere.'
  - answer: Alice
    hint: 'Starts with A

      5 letters

      A standard office name that sounds
      like someone who already invited you to a meeting.'
  companyCards:
  - answer: Amazon
    hint: 'Starts with A

      6 letters

      Online shopping giant where packages
      appear at your door before you even remember ordering them.'
  - answer: Google
    hint: 'Starts with G

      6 letters

      Search engine giant that probably
      knows your question before you finish typing it.'
  - answer: Microsoft
    hint: 'Starts with M

      9 letters

      The company behind Windows, Excel,
      and more meetings than any human deserves.'
  - answer: Nvidia
    hint: 'Starts with N

      6 letters

      Chip company currently powering
      every second AI startup pitch deck.'
  - answer: Tesla
    hint: 'Starts with T

      5 letters

      Electric car company run by the
      same billionaire who also treats space as a side quest.'
  - answer: Netflix
    hint: 'Starts with N

      7 letters

      Streaming company that keeps asking
      if you''re still watching while deadlines approach.'
  - answer: Apple
    hint: 'Starts with A

      5 letters

      Tech company famous for premium
      devices and making wallets feel lighter.'
  - answer: OpenAI
    hint: 'Starts with O

      6 letters

      AI company that somehow became everyone''s
      coworker, tutor, and debugging partner.'
