  m_Script: {fileID: 11500000, guid: 8fa7021a513b3e94bae5dd1425baf1f2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::IntroDialogue
  lines:
  - I finally did it. Bachelor of Science in Software Engineering. Main character
    arc unlocked
  - "Four years of debugging at 3 a.m., living on instant noodles, and running the
    \u2018no shower, no sunlight\u2019 developer grindset."
  - "Resume? Still cooking. I mean, I\u2019ve got a Bachelor\u2019s. That counts"
  - "I\u2019m about to grind this job market like it\u2019s a final boss."
  - Six figures a year? Say less.
  dialogueText: {fileID: 1726809123}
  dialoguePanel: {fileID: 668179048}
  controlsHintText: {fileID: 526083689}
  guideFlow: {fileID: 728464754}
