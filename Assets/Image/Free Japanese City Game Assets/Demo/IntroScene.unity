  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "<size=170%><b>Controls & Interaction</b></size>\r\n\r\nUse <b>Arrow keys</b>
    or <b>W A S D</b> to move your character around the city.  \r\nPress <b>ESC</b>
    to open the menu UI and check your current resume score and progress.  \r\nPress
    <b>SPACE</b> to move to the next dialogue line during character conversations.\r\n\r\nWhen
    you move close to an interactive object (task booths, terminals, or event markers),
    a guide panel will appear with details about that activity.  \r\nFollow the hint
    text on screen and press <b>ENTER</b> to start the interaction or begin the conversation.\r\n\r\nChoose
    carefully, build your resume step by step, and avoid wasting attempts.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 772f54b4818134b4a9050aea9c449a7e, type: 2}
